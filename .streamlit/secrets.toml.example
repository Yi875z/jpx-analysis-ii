# ============================================================
# Streamlit Cloud Secrets テンプレート
# ============================================================
# このファイルは Streamlit Cloud デプロイ時に「App settings → Secrets」へ
# 内容を貼り付けるためのテンプレートです。
#
# ローカル実行時は config/.env が優先されるため、このファイルは不要。
# 実物の secrets.toml は .gitignore で除外されています。
# ============================================================

# ─── Supabase ────────────────────────────────────────────
SUPABASE_URL = "https://xxxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY = "eyJ..."          # サービスロールキー（本番運用は anon key + RLS が望ましい）

# ─── Anthropic（AIレポート再生成を Cloud 上で行う場合のみ）────
# Cloud ではダッシュボード閲覧のみなら不要
ANTHROPIC_API_KEY = "sk-ant-api03-..."
CLAUDE_MODEL = "claude-sonnet-4-6"

# ─── アラート通知（任意）─────────────────────────────────
# Cloud から直接 Gmail 送信したい場合のみ設定
# SMTP_USER = "y.ioku1973@gmail.com"
# SMTP_APP_PASSWORD = "xxxx xxxx xxxx xxxx"
# NOTIFY_EMAIL = "y.ioku1973@gmail.com"

# ─── パスワード保護（streamlit-authenticator）────────────
# Cloud は公開URLになるため、必ず認証を設定すること
[auth]
# bcrypt ハッシュ化済みのパスワードを使う（生成方法は DEPLOY.md 参照）
username  = "yioku"
password_hash = "$2b$12$..."
cookie_name   = "jpx_dashboard_auth"
cookie_key    = "ランダム文字列をここに（32文字以上推奨）"
cookie_expiry_days = 30
